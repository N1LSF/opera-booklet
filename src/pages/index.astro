---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookletEditor from '../components/BookletEditor.jsx';
---

<BaseLayout title="Редактор буклета — Опера глазами читателя">
    <div class="page-wrap">
        <header class="app-header">
            <div class="brand">
                <span class="brand-mark">Opera</span>
                <span class="brand-name">Booklet Editor</span>
            </div>
            <p class="hint">
                Редактор буклета «Возьми в оперу». Пишите, форматируйте, добавляйте картинки —
                и нажмите «Скачать PDF».
            </p>
        </header>

        <BookletEditor client:only="react" />
    </div>
</BaseLayout>

<style>
    .page-wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 32px 20px 80px;
    }
    .app-header {
        text-align: center;
        margin-bottom: 28px;
    }
    .brand {
        display: inline-flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 8px;
    }
    .brand-mark {
        font-family: var(--font-head);
        font-size: 1.8rem;
        font-style: italic;
        color: var(--accent-primary);
        font-weight: 600;
    }
    .brand-name {
        font-family: var(--font-ui);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: var(--text-muted);
        font-weight: 600;
    }
    .hint {
        font-size: 0.9rem;
        color: var(--text-muted);
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.5;
    }
</style>